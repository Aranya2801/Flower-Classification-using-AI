# ═══════════════════════════════════════════════════════════════════════════════
# FlowerAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=FlowerAI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-32-char-secret-key-in-production
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Databases ─────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://flower:flowerai_dev@localhost:5432/flowerai
POSTGRES_PASSWORD=flowerai_dev
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=flowerai
REDIS_URL=redis://localhost:6379/0

# ── Vector Databases ──────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
FAISS_INDEX_PATH=data/embeddings/faiss.index
VECTOR_DB=both

# ── Object Storage ────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=data/uploads
S3_BUCKET=flowerai-assets
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GCS_BUCKET=flowerai-gcs

# ── ML Models ─────────────────────────────────────────────────────────────────
# Options: cpu | cuda | mps | auto
DEVICE=cpu
MODEL_PRECISION=fp32
MODELS_DIR=data/models
# Comma-separated list of enabled models
# ENABLED_MODELS=efficientnet_b7,vit_large_16,convnext_xlarge,swin_large,clip_vit_l14,dinov2_vitl14

# ── LLM & RAG ─────────────────────────────────────────────────────────────────
# Options: openai | gemini | anthropic | local
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-google-gemini-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o
RAG_TOP_K=5

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BURST=20

# ── MLOps ─────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_PROJECT=flower-ai
WANDB_ENTITY=your-wandb-username
WANDB_API_KEY=your-wandb-api-key-here

# ── Monitoring ────────────────────────────────────────────────────────────────
DRIFT_DETECTION_ENABLED=true
DRIFT_CHECK_INTERVAL_HOURS=6
ALERT_EMAIL=alerts@yourorg.com

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=flowerai_grafana_dev
