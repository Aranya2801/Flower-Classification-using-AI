# ═══════════════════════════════════════════════════════════════════════════════
# FlowerAI — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.pem
*.key
*.crt
secrets/
vault/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.pyenv
.python-version
Pipfile.lock
poetry.lock

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints
*/.ipynb_checkpoints/*
*.ipynb_metadata

# ── ML Models & Data ──────────────────────────────────────────────────────────
data/models/*.pt
data/models/*.pth
data/models/*.bin
data/models/*.onnx
data/models/*.tflite
data/models/*.pkl
data/raw/
data/processed/
data/uploads/
data/embeddings/faiss.index
# Keep DVC-tracked data references
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/models/.gitkeep
!data/embeddings/.gitkeep

# ── ML Experiment Artifacts ───────────────────────────────────────────────────
mlruns/
wandb/
outputs/
checkpoints/
runs/
lightning_logs/
.neptune/

# ── Node.js / Frontend ────────────────────────────────────────────────────────
node_modules/
.next/
out/
.nuxt/
dist/
.cache/
.parcel-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn/

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Terraform ────────────────────────────────────────────────────────────────
infrastructure/terraform/**/.terraform/
infrastructure/terraform/**/*.tfstate
infrastructure/terraform/**/*.tfstate.backup
infrastructure/terraform/**/*.tfplan
infrastructure/terraform/**/.terraform.lock.hcl
infrastructure/terraform/**/terraform.tfvars
!infrastructure/terraform/**/terraform.tfvars.example

# ── Testing & Coverage ────────────────────────────────────────────────────────
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.tox/
.nox/
nosetests.xml
test-results/
junit.xml
bandit-report.json

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.ropeproject
.spyproject
.spyderproject.cfg
*.sublime-project
*.sublime-workspace

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.tmp/
reports/
*.csv
!configs/*.csv
